# # Copy to .env and fill in real values. Never commit .env to git.
# # Placeholder-looking values (your_*, xxxx, etc.) are ignored by the server.

# # GitHub — optional but recommended (higher rate limits)
# # https://github.com/settings/tokens → classic token, scope: public_repo
# GITHUB_TOKEN=

# # AI — need at least ONE for "Explain with AI", or run Ollama locally
# # Gemini is free: https://aistudio.google.com/app/apikey
# GEMINI_API_KEY=

# # Optional extra providers (router rotates through configured keys)
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# GROK_API_KEY=
# DEEPSEEK_API_KEY=

# # Local fallback when cloud providers are exhausted (optional)
# OLLAMA_HOST=http://localhost:11434
# OLLAMA_MODEL=llama3.2

# PORT=5000
